# 單一連線字串（優先於下方 db_*）
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# 或沿用分欄位（與現有 .env 相容）
DB_HOST=188.166.189.128
DB_USER=dev_opshop
DB_PASSWORD=Zd53584sc3iYxZP8
DB_NAME=dev_opshop
# db_port=5432

# 可選：prefer（預設）| require | verify-full | disable 等；正式環境建議 require
# 若出現 ECONNRESET / TLS 交握中斷，可改為 disable（僅在不使用 TLS 的 DB 時）
# DB_SSLMODE=require
# DB_SSLMODE=disable

# 開發連線若遇 SSL 憑證驗證失敗，可暫設為 false（勿在正式環境關閉）
# DB_SSL_REJECT_UNAUTHORIZED=false

# 登入 JWT 簽章（正式環境請使用長隨機字串；開發環境可不填，會使用 nuxt 內建預設值）
# JWT_SECRET=

# 租戶子網域根（Cookie Domain、登入後導向子站用；預設 shopgo.com.hk）
# NUXT_PUBLIC_TENANT_ROOT_DOMAIN=shopgo.com.hk

# 自訂網域：租戶「流量 CNAME」要指向的主機名 = Cloudflare Custom Hostnames 的 Fallback Origin（完整 FQDN）
# 須與 CF 控制台 Fallback **逐字相同**（例 shopgo.com.hk）。
# API 自動建立 Custom Hostname 時會將此值寫入 custom_origin_server，使回源 TLS **SNI＝本平台網址**，
# 以免僅有 *.shopgo 憑證的 Caddy 出現 **錯誤 525**（若 SNI 變成租戶網域則握手失敗）。
# 例：NUXT_PUBLIC_SAAS_CNAME_TARGET=shopgo.com.hk
# NUXT_PUBLIC_SAAS_CNAME_TARGET=
# Cloudflare「DCV Delegation」畫面上的後綴（勿含主機名前綴）
# NUXT_PUBLIC_SAAS_DCV_DELEGATION_SUFFIX=4f84583b76a2daff.dcv.cloudflare.com
# 選填：說明／客服連結
# NUXT_PUBLIC_SAAS_SUPPORT_DOC_URL=https://

# 自訂網域：後台「新增」時自動呼叫 Cloudflare Custom Hostnames API（與 NUXT_PUBLIC_SAAS_CNAME_TARGET 同一 zone）
# Token 需含 SSL and Certificates（Custom Hostnames）與 Zone 讀寫權限；勿提交到版本庫
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# openssl rand -base64 32
# [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Minimum 0 -Maximum 256) }))
PAYMENT_SECRETS_KEY=WSqNpfPzBzFitvB6PkDf4QF8wtFcNVjr3NWX873q8eQ=