# 單一連線字串（優先於下方 db_*）
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# 或沿用分欄位（與現有 .env 相容）
db_host=
db_user=
db_password=
db_name=
# db_port=5432

# 可選：prefer（預設）| require | verify-full | disable 等；正式環境建議 require
# DB_SSLMODE=require

# 開發連線若遇 SSL 憑證驗證失敗，可暫設為 false（勿在正式環境關閉）
# DB_SSL_REJECT_UNAUTHORIZED=false

# 登入 JWT 簽章（正式環境請使用長隨機字串；開發環境可不填，會使用 nuxt 內建預設值）
# JWT_SECRET=

# 租戶子網域根（Cookie Domain、登入後導向子站用；預設 oshop.com.hk）
# NUXT_PUBLIC_TENANT_ROOT_DOMAIN=oshop.com.hk


# openssl rand -base64 32
# [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Minimum 0 -Maximum 256) }))
PAYMENT_SECRETS_KEY=WSqNpfPzBzFitvB6PkDf4QF8wtFcNVjr3NWX873q8eQ=