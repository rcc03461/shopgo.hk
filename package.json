{
  "name": "hxm-oshop",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs build",
    "dev": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs dev --host 0.0.0.0",
    "generate": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs generate",
    "start": "node --max-old-space-size=4096 .output/server/index.mjs",
    "preview": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:catalog": "tsx scripts/db-seed-catalog.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@he-tree/vue": "^2.10.5",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@sentry/nuxt": "10",
    "@vueup/vue-quill": "^1.2.0",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "markdown-it": "^14.1.1",
    "nuxt": "^4.4.2",
    "postgres": "^3.4.9",
    "quill": "^2.0.3",
    "sanitize-html": "^2.17.3",
    "turndown": "^7.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "@vercel/nft": "^0.27.4"
  }
}